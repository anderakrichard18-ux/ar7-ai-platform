# ============================================
# Environment Variables Configuration
# ============================================
# Copy this file to .env.local and fill in your actual values
# This file is checked into version control as a reference

# ============================================
# SUPABASE Configuration (Required)
# ============================================
# Get these values from https://app.supabase.com/

# Supabase project URL
NEXT_PUBLIC_SUPABASE_URL=https://rgtzfimejevinctpvzdz.supabase.co

# Supabase publishable/anonymous key (safe to expose to browser)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_DbBbwE2OVOzHsvtMKfE9PQ_8ttrU06r

# Supabase service role key (server-side only, NEVER expose to browser)
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ============================================
# OpenAI Configuration (Required)
# ============================================
# Get this from https://platform.openai.com/api-keys

# OpenAI API Key for accessing GPT and other models
OPENAI_API_KEY=sk-your_openai_api_key_here

# ============================================
# Application Configuration (Optional)
# ============================================

# Node environment (development, production, test)
# Default: development
NODE_ENV=development

# Application base URL for internal references
# Default: http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ============================================
# Development Notes
# ============================================
# 1. Create .env.local file with your actual values:
#    cp .env.example .env.local
#
# 2. Never commit .env.local or other .env files to version control
#    (they're already in .gitignore)
#
# 3. For production, set environment variables in your hosting platform:
#    - Vercel: Project Settings > Environment Variables
#    - Docker: Use -e flag or .env file
#    - Other: Use your platform's configuration management
#
# 4. Server-side variables (without NEXT_PUBLIC_ prefix):
#    - SUPABASE_SERVICE_ROLE_KEY
#    - OPENAI_API_KEY
#    Only accessible on the server, never exposed to the browser
#
# 5. Client-side variables (with NEXT_PUBLIC_ prefix):
#    - NEXT_PUBLIC_SUPABASE_URL
#    - NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY
#    - NEXT_PUBLIC_APP_URL
#    These are accessible in the browser
